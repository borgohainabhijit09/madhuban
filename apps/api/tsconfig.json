{
  "compilerOptions": {
    // Environment Settings
    "module": "CommonJS",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "target": "esnext",
    "esModuleInterop": true,
    "types": ["node"],

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,

    // Recommended Options
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true
  }
}
